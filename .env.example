# === LLM Provider (choose at least one) ===
OPENAI_API_KEY=sk-your-openai-key
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
# GROQ_API_KEY=gsk_your-groq-key
# DEEPSEEK_API_KEY=your-deepseek-key
# GOOGLE_API_KEY=your-google-key

# === LLM Configuration ===
LLM_PROVIDER=openai          # openai, anthropic, ollama, groq, deepseek, google
LLM_MODEL=gpt-4o             # Model name for the chosen provider

# === Optional: Override for local models ===
# OLLAMA_BASE_URL=http://localhost:11434

# === Optional: Twitter/X API (for social sentiment) ===
# TWITTER_BEARER_TOKEN=your-twitter-bearer-token
# Get one at: https://developer.twitter.com/en/portal/dashboard
