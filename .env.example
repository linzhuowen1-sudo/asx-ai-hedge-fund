# === LLM Configuration ===
# Default: Ollama (local, no API key needed)
LLM_PROVIDER=ollama           # ollama, openai, anthropic, groq, deepseek, google
LLM_MODEL=qwen3.5:cloud   # Model name for the chosen provider

# === Optional: Cloud LLM providers ===
# OPENAI_API_KEY=sk-your-openai-key
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
# GROQ_API_KEY=gsk_your-groq-key
# DEEPSEEK_API_KEY=your-deepseek-key
# GOOGLE_API_KEY=your-google-key

# === Optional: Override Ollama URL ===
# OLLAMA_BASE_URL=http://localhost:11434

# === Note ===
# Default setup requires NO API keys — uses Ollama for LLM and opencli for news.
# Install Ollama: https://ollama.ai
# Install opencli: npm install -g @jackwener/opencli
